generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums (16 per data-model.md) ────────────────────────────────────────────

enum CampaignStatus {
  draft
  in_review
  pitching
  live
  reporting
  closed
  paused
  cancelled
}

enum CampaignPhase {
  brief_intake
  ai_structuring
  budget_review
  influencer_matching
  client_pitching
  content_production
  performance_tracking
  report_generation
  closure
}

enum RiskLevel {
  low
  medium
  high
}

enum RoleName {
  director
  campaign_manager
  reviewer
  finance
  client
  influencer
}

enum InfluencerLifecycleStatus {
  proposed
  approved
  contracted
  brief_accepted
  live
  completed
}

enum ContentType {
  script
  video_draft
  final
}

enum ContentApprovalStatus {
  pending
  internal_approved
  client_approved
  changes_requested
}

enum InvoiceType {
  client
  influencer
}

enum InvoiceStatus {
  draft
  sent
  approved
  paid
}

enum ReportStatus {
  draft
  pending_approval
  approved
  exported
}

enum ApprovalType {
  budget
  shortlist
  content_internal
  content_client
  report
  exception
  high_risk_override
  registration
}

enum KPISource {
  manual
  auto
}

enum ProfileStatus {
  complete
  stub
}

enum ClientType {
  company
  individual
}

enum RegistrationStatus {
  pending
  approved
  rejected
}

enum ExceptionType {
  urgent_posting
  verbal_approval
  client_timeout
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  userId                  String                   @id @default(uuid()) @map("user_id")
  email                   String                   @unique @map("email")
  passwordHash            String                   @map("password_hash")
  fullName                String                   @map("full_name")
  displayName             String?                  @map("display_name")
  phone                   String?                  @map("phone")
  profileImageUrl         String?                  @map("profile_image_url")
  role                    String                   @default("client_manager") @map("role")
  isActive                Boolean                  @default(true) @map("is_active")
  isEmailVerified         Boolean                  @default(false) @map("is_email_verified")
  failedLoginCount        Int                      @default(0) @map("failed_login_count")
  lockedUntil             DateTime?                @map("locked_until")
  managedClientId         String?                  @map("managed_client_id")
  managedInfluencerId     String?                  @map("managed_influencer_id")
  lastLoginAt             DateTime?                @map("last_login_at")
  passwordResetToken      String?                  @map("password_reset_token")
  passwordResetExpires    DateTime?                @map("password_reset_expires")
  emailVerificationToken  String?                  @map("email_verification_token")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")

  // Existing relations
  media                   Media[]                  @relation("UserMedia")
  notificationPreferences NotificationPreferences? @relation("UserNotificationPreferences")
  notifications           Notification[]           @relation("UserNotifications")
  managedClient           Client?                  @relation("ManagedClient", fields: [managedClientId], references: [clientId])
  managedInfluencer       Influencer?              @relation("ManagedInfluencer", fields: [managedInfluencerId], references: [influencerId])

  // V2 relations
  roles                   UserRole[]
  profile                 Profile?
  auditLogs               AuditLog[]
  reminders               Reminder[]
  ownedCampaigns          Campaign[]               @relation("CampaignOwner")
  companyRegistration     CompanyRegistration?

  @@index([email])
  @@index([role])
  @@index([managedClientId])
  @@index([managedInfluencerId])
  @@map("users")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      RoleName
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId])

  @@unique([userId, role])
  @@map("user_roles")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  fullName  String   @map("full_name")
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId])

  @@map("profiles")
}

model CompanyRegistration {
  id              String             @id @default(cuid())
  userId          String             @unique @map("user_id")
  companyName     String?            @map("company_name")
  vatTrnNumber    String?            @map("vat_trn_number")
  licenseNumber   String?            @map("license_number")
  expiryDate      DateTime?          @map("expiry_date")
  businessAddress String?            @map("business_address")
  activities      String?            // JSON array
  ownerNames      String?            @map("owner_names") // JSON array
  licenseFileUrl  String?            @map("license_file_url")
  status          RegistrationStatus @default(pending)
  reviewedBy      String?            @map("reviewed_by")
  rejectionReason String?            @map("rejection_reason")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId])

  @@map("company_registrations")
}

model Client {
  clientId               String     @id @default(uuid()) @map("client_id")
  displayId              String?    @unique @map("display_id") // CLI-XXXX
  type                   ClientType @default(company)
  legalCompanyName       String     @map("legal_company_name")
  brandDisplayName       String     @map("brand_display_name")
  industryVertical       String?    @map("industry_vertical")
  primaryContactEmails   String     @map("primary_contact_emails")
  billingContactEmails   String     @map("billing_contact_emails")
  preferredCommChannels  String     @map("preferred_comm_channels")
  phone                  String?    @map("phone")
  avatar                 String?    @map("avatar")
  totalAdSpend           Float?     @default(0) @map("total_ad_spend")
  performanceMetricsJson String?    @map("performance_metrics_json")
  accountCreatedAt       DateTime   @default(now()) @map("account_created_at")
  lastModifiedAt         DateTime   @updatedAt @map("last_modified_at")

  campaigns   Campaign[]
  managers    User[]                     @relation("ManagedClient")
  assignments CampaignClientAssignment[]

  @@map("clients")
}

model Campaign {
  campaignId            String          @id @default(uuid()) @map("campaign_id")
  displayId             String?         @unique @map("display_id") // TKT-YYYY-XXXX
  campaignName          String          @map("campaign_name")
  campaignDescription   String?         @map("campaign_description")
  campaignObjectives    String?         @map("campaign_objectives")
  status                CampaignStatus  @default(draft) @map("status")
  phase                 CampaignPhase   @default(brief_intake) @map("phase")
  riskLevel             RiskLevel       @default(low) @map("risk_level")
  riskScore             Int             @default(0) @map("risk_score")
  totalBudget           Float?          @map("total_budget")
  managementFee         Float           @default(30) @map("management_fee")
  allocatedBudget       Float?          @default(0) @map("allocated_budget")
  spentBudget           Float?          @default(0) @map("spent_budget")
  startDate             DateTime?       @map("start_date")
  endDate               DateTime?       @map("end_date")
  launchDate            DateTime?       @map("launch_date")
  closedAt              DateTime?       @map("closed_at")
  isDeleted             Boolean         @default(false) @map("is_deleted")
  version               Int             @default(1) @map("version")
  clientId              String?         @map("client_id")
  ownerId               String?         @map("owner_id")
  targetAudienceJson    String?         @map("target_audience_json")
  targetPlatformsJson   String?         @map("target_platforms_json")
  performanceKPIsJson   String?         @map("performance_kpis_json")
  actualPerformanceJson String?         @map("actual_performance_json")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  // Existing relations
  client              Client?                    @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  briefs              Brief[]
  campaignInfluencers CampaignInfluencer[]
  invoices            Invoice[]

  // V2 relations
  owner           User?                      @relation("CampaignOwner", fields: [ownerId], references: [userId])
  strategy        Strategy?
  content         Content[]
  kpis            KPI[]
  kpiSchedules    KPISchedule[]
  budgetRevisions BudgetRevision[]
  reports         Report[]
  approvals       Approval[]
  notifications   Notification[]
  reminders       Reminder[]
  cxSurvey        CXSurvey?
  postMortem      PostMortem?
  assignments     CampaignClientAssignment[]

  @@index([clientId])
  @@index([status])
  @@map("campaigns")
}

model CampaignClientAssignment {
  id           String   @id @default(cuid())
  campaignId   String   @map("campaign_id")
  clientId     String   @map("client_id")
  clientUserId String?  @map("client_user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId])
  client   Client   @relation(fields: [clientId], references: [clientId])

  @@unique([campaignId, clientId])
  @@map("campaign_client_assignments")
}

model Brief {
  id               String   @id @default(cuid())
  campaignId       String   @map("campaign_id")
  version          Int      @default(1)
  rawText          String?  @map("raw_text")
  fileName         String?  @map("file_name")
  fileUrl          String?  @map("file_url")
  objectives       String?
  kpis             String?
  targetAudience   String?  @map("target_audience")
  deliverables     String?
  budgetSignals    String?  @map("budget_signals")
  clientInfo       String?  @map("client_info")
  keyMessages      String?  @map("key_messages")
  contentPillars   String?  @map("content_pillars")
  matchingCriteria String?  @map("matching_criteria")
  confidenceScores String?  @map("confidence_scores") // JSON per-field confidence
  strategy         String?
  aiStatus         String   @default("pending") @map("ai_status")
  extractionStatus String   @default("pending") @map("extraction_status")
  isReviewed       Boolean  @default(false) @map("is_reviewed")
  reviewedBy       String?  @map("reviewed_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  campaign Campaign      @relation(fields: [campaignId], references: [campaignId], onDelete: Cascade)
  versions BriefVersion[]

  @@index([campaignId])
  @@index([aiStatus])
  @@map("briefs")
}

model BriefVersion {
  id               String   @id @default(cuid())
  briefId          String   @map("brief_id")
  versionNumber    Int      @map("version_number")
  objectives       String?
  kpis             String?
  targetAudience   String?  @map("target_audience")
  deliverables     String?
  budgetSignals    String?  @map("budget_signals")
  clientInfo       String?  @map("client_info")
  keyMessages      String?  @map("key_messages")
  contentPillars   String?  @map("content_pillars")
  matchingCriteria String?  @map("matching_criteria")
  changedBy        String?  @map("changed_by")
  createdAt        DateTime @default(now()) @map("created_at")

  brief Brief @relation(fields: [briefId], references: [id])

  @@map("brief_versions")
}

model Strategy {
  id               String   @id @default(cuid())
  campaignId       String   @unique @map("campaign_id")
  summary          String?
  keyMessages      String?  @map("key_messages") // JSON array
  contentPillars   String?  @map("content_pillars") // JSON array
  matchingCriteria String?  @map("matching_criteria") // JSON
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId])

  @@map("strategies")
}

model Influencer {
  influencerId        String        @id @default(uuid()) @map("influencer_id")
  displayId           String?       @unique @map("display_id") // INF-XXXX
  handle              String?       @map("handle")
  fullName            String        @map("full_name")
  displayName         String        @map("display_name")
  email               String        @unique @map("email")
  phone               String?       @map("phone")
  bio                 String?       @map("bio")
  profileImageUrl     String?       @map("profile_image_url")
  platform            String        @default("instagram") @map("platform")
  niches              String?       @map("niches") // JSON array
  geo                 String?       @map("geo")
  language            String?       @map("language")
  followerCount       Int?          @map("follower_count")
  engagementRate      Float?        @map("engagement_rate")
  rateCard            String?       @map("rate_card") // JSON
  tier                String?       @map("tier")
  gender              String?       @map("gender")
  city                String?       @map("city")
  country             String?       @map("country")
  representation      String?       @default("direct") @map("representation")
  agentContact        String?       @map("agent_contact")
  tiktokHandle        String?       @map("tiktok_handle")
  tiktokLink          String?       @map("tiktok_link")
  sociataProfileUrl   String?       @map("sociata_profile_url")
  profileStatus       ProfileStatus @default(stub) @map("profile_status")
  isActive            Boolean       @default(true) @map("is_active")
  // Existing fields kept for backward compatibility
  socialMediaHandles  String?       @map("social_media_handles")
  primaryPlatform     String?       @map("primary_platform")
  audienceMetrics     String?       @map("audience_metrics")
  contentCategories   String?       @map("content_categories")
  performanceHistory  String?       @map("performance_history")
  availabilityStatus  String        @default("available") @map("availability_status")
  ratePerPost         Float?        @map("rate_per_post")
  ratePerVideo        Float?        @map("rate_per_video")
  ratePerStory        Float?        @map("rate_per_story")
  isVerified          Boolean       @default(false) @map("is_verified")
  qualityScore        Float?        @map("quality_score")
  internalNotes       String?       @map("internal_notes")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  campaignInfluencers CampaignInfluencer[]
  users               User[]               @relation("ManagedInfluencer")

  @@index([primaryPlatform])
  @@index([availabilityStatus])
  @@index([isVerified])
  @@map("influencers")
}

model CampaignInfluencer {
  id                  String                    @id @default(uuid())
  campaignId          String                    @map("campaign_id")
  influencerId        String                    @map("influencer_id")
  status              InfluencerLifecycleStatus @default(proposed)
  // Existing fields kept for backward compatibility
  role                String?                   @map("role")
  collaborationStatus String                    @default("invited") @map("collaboration_status")
  agreedDeliverables  String?                   @map("agreed_deliverables")
  deliveredContent    String?                   @map("delivered_content")
  agreedPayment       Float?                    @map("agreed_payment")
  paymentStatus       String                    @default("pending") @map("payment_status")
  performanceMetrics  String?                   @map("performance_metrics")
  // V2 fields
  aiMatchScore        Float?                    @map("ai_match_score")
  aiMatchRationale    String?                   @map("ai_match_rationale")
  estimatedCost       Float?                    @map("estimated_cost")
  agreedCost          Float?                    @map("agreed_cost")
  briefAccepted       Boolean                   @default(false) @map("brief_accepted")
  briefAcceptedAt     DateTime?                 @map("brief_accepted_at")
  contractStatus      String?                   @map("contract_status")
  invitedAt           DateTime                  @default(now()) @map("invited_at")
  approvedAt          DateTime?                 @map("approved_at")
  contractedAt        DateTime?                 @map("contracted_at")
  liveAt              DateTime?                 @map("live_at")
  acceptedAt          DateTime?                 @map("accepted_at")
  completedAt         DateTime?                 @map("completed_at")
  scheduledPostDate   DateTime?                 @map("scheduled_post_date")
  postPlatform        String?                   @map("post_platform")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @default(now()) @updatedAt @map("updated_at")

  campaign   Campaign   @relation(fields: [campaignId], references: [campaignId], onDelete: Cascade)
  influencer Influencer @relation(fields: [influencerId], references: [influencerId], onDelete: Cascade)
  content    Content[]
  kpis       KPI[]

  @@unique([campaignId, influencerId])
  @@index([campaignId])
  @@index([influencerId])
  @@index([collaborationStatus])
  @@map("campaign_influencers")
}

model Content {
  id                  String              @id @default(uuid())
  campaignId          String?             @map("campaign_id")
  type                String
  version             Int                 @default(1)
  approvalStatus      String              @default("pending") @map("approval_status")
  filmingBlocked      Boolean             @default(true) @map("filming_blocked")
  postingBlocked      Boolean             @default(true) @map("posting_blocked")
  fileUrl             String?             @map("file_url")
  fileName            String?             @map("file_name")
  fileSizeBytes       Int?                @map("file_size_bytes")
  livePostUrl         String?             @map("live_post_url")
  internalFeedback    String?             @map("internal_feedback")
  clientFeedback      String?             @map("client_feedback")
  exceptionType       ExceptionType?      @map("exception_type")
  exceptionApprovedBy String?             @map("exception_approved_by")
  exceptionEvidence   String?             @map("exception_evidence")
  description         String?
  collaborationId     String              @map("collaboration_id")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  campaign      Campaign?          @relation(fields: [campaignId], references: [campaignId])
  collaboration CampaignInfluencer @relation(fields: [collaborationId], references: [id], onDelete: Cascade)

  @@index([collaborationId])
  @@index([type])
  @@index([approvalStatus])
  @@map("content")
}

model KPI {
  id                   String              @id @default(cuid())
  campaignId           String              @map("campaign_id")
  campaignInfluencerId String?             @map("campaign_influencer_id")
  reach                Int?
  impressions          Int?
  engagement           Int?
  clicks               Int?
  captureDay           Int?                @map("capture_day")
  source               KPISource           @default(manual)
  createdAt            DateTime            @default(now()) @map("created_at")

  campaign           Campaign            @relation(fields: [campaignId], references: [campaignId])
  campaignInfluencer CampaignInfluencer? @relation(fields: [campaignInfluencerId], references: [id])

  @@map("kpis")
}

model KPISchedule {
  id                   String    @id @default(cuid())
  campaignId           String    @map("campaign_id")
  campaignInfluencerId String    @map("campaign_influencer_id")
  captureDay           Int       @map("capture_day")
  scheduledAt          DateTime  @map("scheduled_at")
  capturedAt           DateTime? @map("captured_at")
  isFailed             Boolean   @default(false) @map("is_failed")
  createdAt            DateTime  @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId])

  @@map("kpi_schedules")
}

model Report {
  id           String       @id @default(cuid())
  campaignId   String       @map("campaign_id")
  status       ReportStatus @default(draft)
  kpiSummary   String?      @map("kpi_summary") // JSON
  highlights   String?
  aiNarrative  String?      @map("ai_narrative")
  approvedBy   String?      @map("approved_by")
  approvedAt   DateTime?    @map("approved_at")
  exportedAt   DateTime?    @map("exported_at")
  shareableUrl String?      @map("shareable_url")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId])

  @@map("reports")
}

model Invoice {
  id            String    @id @default(uuid())
  displayId     String?   @unique @map("display_id") // INV-YYYY-XXXX
  invoiceNumber String?   @map("invoice_number")
  type          String
  status        String    @default("draft")
  amount        Float
  currency      String    @default("AED")
  dueDate       DateTime? @map("due_date")
  fileUrl       String?   @map("file_url")
  notes         String?
  campaignId    String    @map("campaign_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
  @@map("invoices")
}

model BudgetRevision {
  id             String   @id @default(cuid())
  campaignId     String   @map("campaign_id")
  previousBudget Float    @map("previous_budget")
  newBudget      Float    @map("new_budget")
  changedBy      String   @map("changed_by")
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId])

  @@map("budget_revisions")
}

model Approval {
  id         String       @id @default(cuid())
  campaignId String       @map("campaign_id")
  type       ApprovalType
  entityId   String?      @map("entity_id")
  status     String       @default("pending")
  approvedBy String?      @map("approved_by")
  rejectedBy String?      @map("rejected_by")
  reason     String?
  evidence   String?
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId])

  @@map("approvals")
}

model Notification {
  notificationId  String    @id @default(uuid()) @map("notification_id")
  userId          String    @map("user_id")
  campaignId      String?   @map("campaign_id")
  notificationType String   @map("notification_type")
  category        String    @map("category")
  title           String    @map("title")
  message         String    @map("message")
  metadata        String?   @map("metadata")
  actionUrl       String?   @map("action_url")
  priority        String    @default("normal") @map("priority")
  isRead          Boolean   @default(false) @map("is_read")
  readAt          DateTime? @map("read_at")
  entityType      String?   @map("entity_type")
  entityId        String?   @map("entity_id")
  isEscalation    Boolean   @default(false) @map("is_escalation")
  escalationLevel Int?      @map("escalation_level")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  user     User      @relation("UserNotifications", fields: [userId], references: [userId], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [campaignId])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreferences {
  preferenceId       String   @id @default(uuid()) @map("preference_id")
  userId             String   @unique @map("user_id")
  emailCampaign      Boolean  @default(true) @map("email_campaign")
  emailCollaboration Boolean  @default(true) @map("email_collaboration")
  emailPayment       Boolean  @default(true) @map("email_payment")
  emailSystem        Boolean  @default(true) @map("email_system")
  inAppCampaign      Boolean  @default(true) @map("inapp_campaign")
  inAppCollaboration Boolean  @default(true) @map("inapp_collaboration")
  inAppPayment       Boolean  @default(true) @map("inapp_payment")
  inAppSystem        Boolean  @default(true) @map("inapp_system")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation("UserNotificationPreferences", fields: [userId], references: [userId], onDelete: Cascade)

  @@map("notification_preferences")
}

model Reminder {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  campaignId  String?   @map("campaign_id")
  entityType  String?   @map("entity_type")
  entityId    String?   @map("entity_id")
  title       String
  description String?
  dueDate     DateTime  @map("due_date")
  isSent      Boolean   @default(false) @map("is_sent")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [userId])
  campaign Campaign? @relation(fields: [campaignId], references: [campaignId])

  @@map("reminders")
}

model CXSurvey {
  id                 String   @id @default(cuid())
  campaignId         String   @unique @map("campaign_id")
  overallScore       Int      @map("overall_score")
  communicationScore Int      @map("communication_score")
  qualityScore       Int      @map("quality_score")
  timelinessScore    Int      @map("timeliness_score")
  valueScore         Int      @map("value_score")
  testimonial        String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId])

  @@map("cx_surveys")
}

model PostMortem {
  id               String   @id @default(cuid())
  campaignId       String   @unique @map("campaign_id")
  wentWell         String?  @map("went_well") // JSON array
  improvements     String?  // JSON array
  lessons          String?  // JSON array
  actionItems      String?  @map("action_items") // JSON array
  riskNotes        String?  @map("risk_notes")
  budgetAnalysis   String?  @map("budget_analysis")
  timelineAnalysis String?  @map("timeline_analysis")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [campaignId])

  @@map("post_mortems")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  changes    String?  // JSON diff
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId])

  @@map("audit_logs")
}

model InstagramConnection {
  id           String    @id @default(cuid())
  accessToken  String    @map("access_token")
  refreshToken String?   @map("refresh_token")
  tokenExpiry  DateTime? @map("token_expiry")
  igUserId     String?   @map("ig_user_id")
  igUsername   String?   @map("ig_username")
  pageId       String?   @map("page_id")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("instagram_connections")
}

model Media {
  mediaId      String   @id @default(uuid()) @map("media_id")
  userId       String   @map("user_id")
  filename     String   @map("filename")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int      @map("size")
  url          String   @map("url")
  thumbnailUrl String?  @map("thumbnail_url")
  entityType   String?  @map("entity_type")
  entityId     String?  @map("entity_id")
  purpose      String   @default("general") @map("purpose")
  isPublic     Boolean  @default(false) @map("is_public")
  metadata     String?  @map("metadata")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation("UserMedia", fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([purpose])
  @@map("media")
}
